---
const { title = 'Seller AI HQ', description = 'AI tools, workflows, and practical guides for online sellers.' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
      :root {
        color-scheme: dark;
        --bg: #070b17;
        --bg-2: #0d1428;
        --panel: rgba(14, 21, 40, 0.88);
        --panel-strong: #111a33;
        --soft: #182445;
        --text: #eef2ff;
        --muted: #9dabcf;
        --accent: #6ea8ff;
        --accent-2: #8d6bff;
        --accent-3: #29d3a1;
        --border: rgba(255,255,255,0.08);
        --border-strong: rgba(255,255,255,0.14);
        --shadow: 0 20px 60px rgba(0,0,0,0.35);
        --max: 1160px;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background:
          radial-gradient(circle at top left, rgba(110,168,255,0.14), transparent 30%),
          radial-gradient(circle at top right, rgba(141,107,255,0.14), transparent 30%),
          linear-gradient(180deg, var(--bg) 0%, var(--bg-2) 100%);
        color: var(--text);
        line-height: 1.55;
      }
      a { color: inherit; text-decoration: none; }
      .wrap { width: min(100% - 32px, var(--max)); margin: 0 auto; }
      .nav {
        display: flex; align-items: center; justify-content: space-between;
        padding: 20px 0;
        position: sticky; top: 0; z-index: 20;
        backdrop-filter: blur(14px);
      }
      .brand {
        font-weight: 800; letter-spacing: 0.02em; font-size: 18px;
        display: inline-flex; gap: 2px; align-items: center;
      }
      .brand span { color: var(--accent); }
      .navlinks { display: flex; gap: 18px; color: var(--muted); font-size: 14px; align-items: center; }
      .navlinks a:hover { color: var(--text); }
      .navcta {
        padding: 10px 14px; border-radius: 12px;
        background: rgba(110,168,255,0.12); border: 1px solid var(--border);
        color: #dce7ff;
      }
      .card {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 24px;
        padding: 28px;
        backdrop-filter: blur(14px);
        box-shadow: var(--shadow);
      }
      .pill {
        display:inline-flex; align-items:center; gap:8px;
        font-size: 12px; color:#d8e4ff;
        background: rgba(110,168,255,0.1);
        border: 1px solid rgba(110,168,255,0.18);
        padding: 7px 11px; border-radius: 999px; margin-bottom: 12px;
      }
      h1, h2, h3 { letter-spacing: -0.03em; }
      h1 { font-size: clamp(40px, 7vw, 74px); line-height: 0.97; margin: 0 0 18px; }
      h2 { font-size: clamp(28px, 4vw, 42px); margin: 0 0 10px; }
      h3 { font-size: 22px; margin: 0 0 8px; }
      .top, .mini, .lead { color: var(--muted); }
      .lead { font-size: 18px; max-width: 700px; }
      .mini { font-size: 14px; }
      .section { padding: 28px 0; }
      .hero { padding: 52px 0 24px; }
      .hero-grid { display: grid; grid-template-columns: 1.25fr 0.75fr; gap: 22px; }
      .cta-row { display: flex; gap: 12px; margin-top: 28px; flex-wrap: wrap; }
      .btn {
        display: inline-flex; align-items: center; justify-content: center;
        padding: 14px 18px; border-radius: 14px; font-weight: 700;
        transition: transform .15s ease, opacity .15s ease;
      }
      .btn:hover { transform: translateY(-1px); }
      .btn.primary { background: linear-gradient(135deg, var(--accent), var(--accent-2)); color: white; }
      .btn.secondary { background: rgba(255,255,255,0.04); color: var(--text); border: 1px solid var(--border); }
      .stats { display: grid; grid-template-columns: repeat(3,1fr); gap: 12px; margin-top: 18px; }
      .stat {
        background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));
        border: 1px solid var(--border);
        border-radius: 18px; padding: 16px;
      }
      .stat strong { display:block; font-size: 26px; margin-bottom: 4px; }
      .grid-3 { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; }
      .grid-2 { display: grid; grid-template-columns: repeat(2,1fr); gap: 16px; }
      .feature-list { display: grid; gap: 14px; }
      .feature {
        padding: 16px 18px; border-radius: 18px;
        border: 1px solid var(--border);
        background: rgba(255,255,255,0.025);
      }
      .feature strong { display:block; margin-bottom: 6px; }
      .trust {
        display:grid; grid-template-columns: repeat(4,1fr); gap: 12px;
      }
      .trust .card { padding: 18px; }
      .accent-line {
        background: linear-gradient(90deg, var(--accent), var(--accent-2), var(--accent-3));
        height: 1px; opacity: 0.5; margin: 10px 0 0;
      }
      footer { padding: 40px 0 60px; color: var(--muted); font-size: 14px; }
      @media (max-width: 980px) {
        .hero-grid, .grid-3, .grid-2, .trust { grid-template-columns: 1fr; }
        .navlinks { display: none; }
      }
    </style>
  </head>
  <body>
    <div class="wrap">
      <header class="nav">
        <div class="brand">Seller<span>AI</span>HQ</div>
        <nav class="navlinks">
          <a href="/tools">Tools</a>
          <a href="/guides">Guides</a>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
          <a class="navcta" href="https://x.com/selleraihq" target="_blank" rel="noreferrer">Follow on X</a>
        </nav>
      </header>
      <slot />
      <footer>
        <div>SellerAIHQ.com, practical AI for sellers.</div>
        <div class="mini" style="margin-top:8px;">Focused on useful AI stacks, workflows, and scalable seller infrastructure.</div>
      </footer>
    </div>
  </body>
</html>
