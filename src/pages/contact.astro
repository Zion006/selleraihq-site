    <div class="card">
      <div class="pill">Contact</div>
      <h1 style="font-size:42px; margin-bottom:14px;">Partnerships, feedback, and tool suggestions.</h1>
      <p class="top">For now, contact happens through our X account and project email. A proper contact workflow will be added next.</p>
      <ul class="clean">
        <li>X: <a href="https://x.com/selleraihq" target="_blank" rel="noreferrer">@selleraihq</a></li>
        <li>Website: selleraihq.com</li>
      </ul>
    </div>
  </section>
</BaseLayout>
