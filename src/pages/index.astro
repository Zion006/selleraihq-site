---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Seller AI HQ — AI tools built for Amazon FBA sellers"
  description="Practical AI tools for Amazon FBA sellers. Reimbursement audits, listing optimization, inventory intelligence. Built to find money you're leaving on the table."
>
<style>
  /* ── ANIMATIONS ── */
  @keyframes fadeUp   { from { opacity:0; transform:translateY(24px); } to { opacity:1; transform:translateY(0); } }
  @keyframes fadeIn   { from { opacity:0; } to { opacity:1; } }
  @keyframes pulse    { 0%,100%{ box-shadow:0 0 0 0 rgba(41,211,161,0.4); } 60%{ box-shadow:0 0 0 8px rgba(41,211,161,0); } }
  @keyframes float    { 0%,100%{ transform:translateY(0); } 50%{ transform:translateY(-8px); } }
  @keyframes shimmer  { 0%{ background-position:200% center; } 100%{ background-position:-200% center; } }
  @keyframes glow     { 0%,100%{ opacity:.5; } 50%{ opacity:1; } }
  @keyframes spin     { to { transform:rotate(360deg); } }
  @keyframes countUp  { from { opacity:0; } to { opacity:1; } }

  .reveal { opacity:0; transform:translateY(28px); transition: opacity .7s ease, transform .7s ease; }
  .reveal.visible { opacity:1; transform:translateY(0); }
  .reveal-delay-1 { transition-delay:.1s; }
  .reveal-delay-2 { transition-delay:.2s; }
  .reveal-delay-3 { transition-delay:.3s; }
  .reveal-delay-4 { transition-delay:.4s; }
  .reveal-delay-5 { transition-delay:.5s; }

  /* ── HERO ── */
  .hero { padding: 72px 0 40px; position:relative; overflow:hidden; }

  .hero-bg {
    position:absolute; inset:0; pointer-events:none; z-index:0;
    background:
      radial-gradient(ellipse 60% 40% at 20% 0%, rgba(110,168,255,.15), transparent),
      radial-gradient(ellipse 40% 50% at 80% 10%, rgba(141,107,255,.12), transparent),
      radial-gradient(ellipse 30% 30% at 50% 80%, rgba(41,211,161,.06), transparent);
  }

  /* floating dots grid */
  .dots-bg {
    position:absolute; inset:0; pointer-events:none; z-index:0;
    background-image: radial-gradient(circle, rgba(255,255,255,.06) 1px, transparent 1px);
    background-size: 28px 28px;
    mask-image: radial-gradient(ellipse 80% 60% at 50% 0%, black, transparent);
  }

  .hero-content { position:relative; z-index:1; }

  .hero-eyebrow {
    display:inline-flex; align-items:center; gap:8px;
    font-size:11px; font-weight:700; letter-spacing:1.5px;
    color:var(--accent-3); text-transform:uppercase;
    margin-bottom:22px;
    animation: fadeUp .6s ease both;
  }
  .hero-eyebrow-line { width:28px; height:2px; background:var(--accent-3); border-radius:2px; }

  .hero h1 {
    font-size:clamp(48px,8vw,88px); line-height:.93; letter-spacing:-.04em;
    margin:0 0 22px;
    animation: fadeUp .7s .1s ease both;
  }
  .grad-text {
    background: linear-gradient(90deg, var(--accent), var(--accent-2), var(--accent-3), var(--accent));
    background-size: 200% auto;
    -webkit-background-clip:text; -webkit-text-fill-color:transparent;
    animation: shimmer 4s linear infinite;
  }

  .hero-lead {
    font-size:18px; color:var(--muted); max-width:520px; line-height:1.65;
    margin-bottom:36px;
    animation: fadeUp .7s .2s ease both;
  }

  .hero-btns {
    display:flex; gap:12px; flex-wrap:wrap; margin-bottom:56px;
    animation: fadeUp .7s .3s ease both;
  }

  .btn-glow {
    display:inline-flex; align-items:center; gap:8px;
    padding:14px 22px; border-radius:14px; font-weight:700; font-size:15px;
    background:linear-gradient(135deg, var(--accent), var(--accent-2));
    color:white; position:relative; overflow:hidden;
    transition: transform .15s ease, box-shadow .2s ease;
    box-shadow: 0 0 0 0 rgba(110,168,255,0);
  }
  .btn-glow:hover {
    transform:translateY(-2px);
    box-shadow: 0 8px 32px rgba(110,168,255,.35), 0 2px 8px rgba(0,0,0,.3);
  }
  .btn-glow::after {
    content:''; position:absolute; inset:0;
    background:linear-gradient(135deg, rgba(255,255,255,.15), transparent);
    opacity:0; transition:opacity .2s;
  }
  .btn-glow:hover::after { opacity:1; }

  .btn-ghost {
    display:inline-flex; align-items:center; gap:8px;
    padding:14px 22px; border-radius:14px; font-weight:600; font-size:15px;
    background:rgba(255,255,255,.04); border:1px solid var(--border-strong);
    color:var(--text); transition:background .15s, transform .15s;
  }
  .btn-ghost:hover { background:rgba(255,255,255,.08); transform:translateY(-1px); }

  /* ── FEATURED TOOL CARD ── */
  .featured-card {
    background:var(--panel-strong);
    border:1px solid rgba(110,168,255,.25);
    border-radius:28px; padding:32px;
    position:relative; overflow:hidden;
    animation: fadeUp .8s .4s ease both;
    transition: border-color .2s, box-shadow .2s;
  }
  .featured-card:hover {
    border-color:rgba(110,168,255,.45);
    box-shadow:0 0 40px rgba(110,168,255,.1);
  }
  .featured-card-glow {
    position:absolute; top:-80px; right:-80px;
    width:280px; height:280px; border-radius:50%;
    background:radial-gradient(circle, rgba(110,168,255,.12), transparent 70%);
    pointer-events:none; animation:glow 3s ease infinite;
  }
  .featured-label {
    font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:1.5px;
    color:var(--accent); margin-bottom:10px; display:flex; align-items:center; gap:8px;
  }
  .featured-label::before {
    content:''; display:block; width:6px; height:6px;
    border-radius:50%; background:var(--accent-3);
    animation:pulse 2s infinite;
  }
  .featured-card h2 { font-size:24px; margin:0 0 10px; }
  .featured-card p  { font-size:14px; color:var(--muted); line-height:1.65; margin-bottom:22px; }

  .metrics { display:flex; gap:28px; margin-bottom:24px; flex-wrap:wrap; }
  .metric strong { display:block; font-size:26px; font-weight:800; line-height:1;
                   color:var(--accent-3); margin-bottom:2px; }
  .metric span   { font-size:11px; color:var(--muted); text-transform:uppercase; letter-spacing:.5px; }

  /* ── STATS BAR ── */
  .stats-bar {
    display:grid; grid-template-columns:repeat(4,1fr);
    gap:1px; background:var(--border); border-radius:20px; overflow:hidden;
    margin:48px 0;
  }
  .stat-item {
    background:var(--panel); padding:22px 20px; text-align:center;
    transition:background .2s;
  }
  .stat-item:hover { background:var(--panel-strong); }
  .stat-num {
    font-size:32px; font-weight:800; line-height:1; margin-bottom:4px;
    background:linear-gradient(135deg, var(--accent), var(--accent-2));
    -webkit-background-clip:text; -webkit-text-fill-color:transparent;
  }
  .stat-label { font-size:12px; color:var(--muted); }

  /* ── TOOLS GRID ── */
  .tools-header { margin-bottom:6px; }
  .tools-subhead { color:var(--muted); margin-bottom:28px; font-size:15px; }

  .tools-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; }

  .tool-card {
    background:var(--panel); border:1px solid var(--border);
    border-radius:22px; padding:24px 22px;
    display:flex; flex-direction:column;
    transition:border-color .2s, transform .2s, box-shadow .2s;
    position:relative; overflow:hidden;
  }
  .tool-card::before {
    content:''; position:absolute; inset:0; border-radius:22px;
    background:linear-gradient(135deg, rgba(110,168,255,.04), transparent);
    opacity:0; transition:opacity .2s;
  }
  .tool-card:hover::before { opacity:1; }
  .tool-card:hover {
    border-color:var(--border-strong);
    transform:translateY(-3px);
    box-shadow:0 12px 40px rgba(0,0,0,.25);
  }
  .tool-card.is-live { border-color:rgba(110,168,255,.2); }
  .tool-card.is-live:hover { border-color:rgba(110,168,255,.45); box-shadow:0 12px 40px rgba(110,168,255,.1); }

  .tool-icon-wrap {
    width:48px; height:48px; border-radius:14px;
    display:flex; align-items:center; justify-content:center;
    font-size:24px; margin-bottom:14px;
    background:rgba(255,255,255,.04); border:1px solid var(--border);
  }
  .tool-card.is-live .tool-icon-wrap { background:rgba(110,168,255,.08); border-color:rgba(110,168,255,.2); }

  .tool-card h3 { font-size:16px; margin:0 0 7px; }
  .tool-card p  { font-size:13px; color:var(--muted); line-height:1.55; flex:1; margin-bottom:18px; }

  .tool-footer { display:flex; align-items:center; justify-content:space-between; }

  .live-badge {
    display:inline-flex; align-items:center; gap:5px;
    font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.5px;
    color:var(--accent-3);
  }
  .live-badge::before {
    content:''; width:6px; height:6px; border-radius:50%;
    background:var(--accent-3); animation:pulse 2s infinite;
  }
  .soon-badge {
    font-size:10px; font-weight:600; text-transform:uppercase; letter-spacing:.5px;
    color:var(--muted); background:rgba(255,255,255,.04);
    border:1px solid var(--border); padding:3px 9px; border-radius:999px;
  }

  .tool-btn {
    font-size:12px; font-weight:700; padding:8px 14px; border-radius:10px;
    transition:opacity .15s, transform .15s;
  }
  .tool-btn:hover { opacity:.8; transform:scale(1.02); }
  .tool-btn.primary { background:linear-gradient(135deg,var(--accent),var(--accent-2)); color:white; }
  .tool-btn.ghost   { background:rgba(255,255,255,.05); color:var(--muted);
                      border:1px solid var(--border); }

  /* ── HOW IT WORKS ── */
  .how-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:0; margin-top:28px; }
  .how-step { padding:0 20px; position:relative; }
  .how-step + .how-step::before {
    content:'→'; position:absolute; left:-6px; top:4px;
    color:rgba(255,255,255,.15); font-size:20px;
  }
  .how-num {
    width:36px; height:36px; border-radius:12px;
    background:linear-gradient(135deg,var(--accent),var(--accent-2));
    display:flex; align-items:center; justify-content:center;
    font-size:14px; font-weight:800; margin-bottom:14px;
    box-shadow:0 4px 16px rgba(110,168,255,.3);
  }
  .how-step h4 { font-size:15px; margin:0 0 6px; }
  .how-step p  { font-size:13px; color:var(--muted); line-height:1.55; }

  /* ── CTA BOTTOM ── */
  .cta-bottom {
    background:linear-gradient(135deg, rgba(110,168,255,.1), rgba(141,107,255,.08), rgba(41,211,161,.05));
    border:1px solid rgba(110,168,255,.2); border-radius:28px;
    padding:52px 40px; text-align:center; margin:20px 0 64px;
    position:relative; overflow:hidden;
  }
  .cta-bottom-glow {
    position:absolute; top:-100px; left:50%; transform:translateX(-50%);
    width:500px; height:300px;
    background:radial-gradient(ellipse, rgba(110,168,255,.1), transparent 70%);
    pointer-events:none;
  }
  .cta-bottom h2 { font-size:clamp(28px,4vw,44px); margin-bottom:12px; position:relative; }
  .cta-bottom p  { color:var(--muted); font-size:16px; max-width:460px; margin:0 auto 28px;
                   line-height:1.65; position:relative; }

  /* ── URGENCY ── */
  .urgency-chip {
    display:inline-flex; align-items:center; gap:7px;
    background:rgba(255,68,68,.1); border:1px solid rgba(255,68,68,.2);
    color:#ff9999; font-size:12px; font-weight:600;
    padding:6px 14px; border-radius:999px; margin-bottom:18px;
  }
  .urgency-chip::before { content:'⚠'; }

  @media(max-width:980px){
    .tools-grid, .how-grid, .stats-bar { grid-template-columns:1fr; }
    .how-step + .how-step::before { display:none; }
  }
</style>

<!-- BG LAYERS -->
<div class="hero-bg"></div>
<div class="dots-bg"></div>

<!-- HERO -->
<section class="hero">
  <div class="hero-content">
    <div class="hero-eyebrow">
      <span class="hero-eyebrow-line"></span>
      Built for Amazon FBA sellers
    </div>

    <h1>Stop leaving<br><span class="grad-text">Amazon money</span><br>on the table.</h1>

    <p class="hero-lead">
      SellerAIHQ builds focused AI tools that find revenue FBA sellers don't know they're losing.
      Upload your data, get findings, take action.
    </p>

    <div class="hero-btns">
      <a class="btn-glow" href="/fba-audit">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        Try Free Audit →
      </a>
      <a class="btn-ghost" href="#tools">See all tools</a>
    </div>

    <!-- Featured tool -->
    <div class="featured-card reveal">
      <div class="featured-card-glow"></div>
      <div class="featured-label">First tool · Live now</div>
      <h2>FBA Underpaid Reimbursement Audit</h2>
      <p>Amazon changed their reimbursement policy in March 2025. If your sourcing costs weren't uploaded correctly, Amazon may have paid less than your real cost for lost or damaged inventory — and you have 60 days to dispute each case.</p>
      <div class="metrics">
        <div class="metric">
          <strong class="counter" data-target="60">0</strong>
          <span>days to dispute</span>
        </div>
        <div class="metric">
          <strong>Mar 2025</strong>
          <span>policy change</span>
        </div>
        <div class="metric">
          <strong>Free</strong>
          <span>diagnostic</span>
        </div>
      </div>
      <a class="btn-glow" href="/fba-audit" style="display:inline-flex">
        Run free diagnostic →
      </a>
    </div>
  </div>
</section>

<!-- STATS -->
<div class="stats-bar reveal">
  <div class="stat-item">
    <div class="stat-num counter" data-target="60">0</div>
    <div class="stat-label">Days to dispute each reimbursement</div>
  </div>
  <div class="stat-item">
    <div class="stat-num">Mar 2025</div>
    <div class="stat-label">Amazon policy change date</div>
  </div>
  <div class="stat-item">
    <div class="stat-num">$299</div>
    <div class="stat-label">Full audit + evidence pack</div>
  </div>
  <div class="stat-item">
    <div class="stat-num counter" data-target="48" data-suffix="h">0</div>
    <div class="stat-label">Free diagnostic turnaround</div>
  </div>
</div>

<!-- TOOLS -->
<section class="section" id="tools">
  <div class="tools-header reveal">
    <div class="pill">All tools</div>
    <h2 style="margin-top:8px">One tool. One problem. One result.</h2>
  </div>
  <p class="tools-subhead reveal reveal-delay-1">Each tool targets a specific revenue leak. No dashboards, no bloat.</p>

  <div class="tools-grid">

    <div class="tool-card is-live reveal reveal-delay-1">
      <div class="tool-icon-wrap">🔍</div>
      <h3>FBA Reimbursement Audit</h3>
      <p>Checks if Amazon underpaid your lost/damaged inventory reimbursements. Calculates delta, flags 60-day deadlines, generates evidence pack for re-evaluation.</p>
      <div class="tool-footer">
        <span class="live-badge">Live now</span>
        <a class="tool-btn primary" href="/fba-audit">Try Free →</a>
      </div>
    </div>

    <div class="tool-card reveal reveal-delay-2">
      <div class="tool-icon-wrap">📦</div>
      <h3>Sourcing Cost Uploader</h3>
      <p>Bulk-upload FNSKU sourcing costs to Manage Your Sourcing Cost before the next reimbursement. Prevents underpayments at the source.</p>
      <div class="tool-footer">
        <span class="soon-badge">Coming soon</span>
        <a class="tool-btn ghost" href="mailto:zionbot@agentmail.to?subject=Waitlist: Sourcing Cost Uploader">Notify me</a>
      </div>
    </div>

    <div class="tool-card reveal reveal-delay-3">
      <div class="tool-icon-wrap">💰</div>
      <h3>FBA Fee Checker</h3>
      <p>Finds SKUs Amazon is overcharging on FBA fees due to misclassified dimensions or weight. $0.30–$2.00 per unit adds up fast.</p>
      <div class="tool-footer">
        <span class="soon-badge">Coming soon</span>
        <a class="tool-btn ghost" href="mailto:zionbot@agentmail.to?subject=Waitlist: FBA Fee Checker">Notify me</a>
      </div>
    </div>

    <div class="tool-card reveal reveal-delay-1">
      <div class="tool-icon-wrap">📋</div>
      <h3>Listing Audit</h3>
      <p>Scans active FBA listings for suppression risks, keyword gaps, and content score issues before Amazon acts on them.</p>
      <div class="tool-footer">
        <span class="soon-badge">Coming soon</span>
        <a class="tool-btn ghost" href="mailto:zionbot@agentmail.to?subject=Waitlist: Listing Audit">Notify me</a>
      </div>
    </div>

    <div class="tool-card reveal reveal-delay-2">
      <div class="tool-icon-wrap">🏷️</div>
      <h3>PPC Waste Finder</h3>
      <p>Identifies search terms bleeding spend with zero ROAS, cannibalizing campaigns, and bids not converting in 90+ days.</p>
      <div class="tool-footer">
        <span class="soon-badge">Coming soon</span>
        <a class="tool-btn ghost" href="mailto:zionbot@agentmail.to?subject=Waitlist: PPC Waste Finder">Notify me</a>
      </div>
    </div>

    <div class="tool-card reveal reveal-delay-3">
      <div class="tool-icon-wrap">🔄</div>
      <h3>Return Rate Analyzer</h3>
      <p>Maps return reasons by ASIN to listing, product, or fulfillment issues. Find what's driving returns before Amazon penalizes you.</p>
      <div class="tool-footer">
        <span class="soon-badge">Coming soon</span>
        <a class="tool-btn ghost" href="mailto:zionbot@agentmail.to?subject=Waitlist: Return Rate Analyzer">Notify me</a>
      </div>
    </div>

  </div>
</section>

<!-- HOW IT WORKS -->
<section class="section reveal">
  <div class="pill">How it works</div>
  <h2 style="margin:8px 0 4px">Upload data. Get findings. Take action.</h2>
  <p class="tools-subhead">Same pattern for every tool. No integrations, no API keys, no setup.</p>
  <div class="how-grid">
    <div class="how-step reveal reveal-delay-1">
      <div class="how-num">1</div>
      <h4>Pick a tool</h4>
      <p>Each tool targets one specific problem. Start with the one most relevant right now.</p>
    </div>
    <div class="how-step reveal reveal-delay-2">
      <div class="how-num">2</div>
      <h4>Export from Seller Central</h4>
      <p>Download the relevant report. Usually 2 minutes of work, no special access needed.</p>
    </div>
    <div class="how-step reveal reveal-delay-3">
      <div class="how-num">3</div>
      <h4>Get your findings</h4>
      <p>We return a clear report — what's wrong, how much it's costing, how confident we are.</p>
    </div>
    <div class="how-step reveal reveal-delay-4">
      <div class="how-num">4</div>
      <h4>Take action</h4>
      <p>Each finding includes an action — claim text, fix instructions, or evidence pack ready to submit.</p>
    </div>
  </div>
</section>

<!-- CTA -->
<div class="cta-bottom reveal">
  <div class="cta-bottom-glow"></div>
  <div class="urgency-chip">Each FBA reimbursement has a 60-day dispute window. Cases expire daily.</div>
  <h2>Start with the free diagnostic</h2>
  <p>Takes 5 minutes to submit your files. We return findings in 24–48 hours.</p>
  <a class="btn-glow" href="/fba-audit" style="font-size:16px;padding:16px 28px;display:inline-flex">
    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
    Run FBA Reimbursement Audit →
  </a>
  <p style="font-size:12px;color:var(--muted);margin-top:12px">Free diagnostic · No commitment · Results in 24–48h</p>
</div>

<script>
  // Scroll reveal
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        // Animate counters
        e.target.querySelectorAll('.counter').forEach(animateCounter);
      }
    });
  }, { threshold: 0.12 });
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  // Also observe counters not inside reveal
  document.querySelectorAll('.counter:not(.reveal .counter)').forEach(el => {
    new IntersectionObserver(entries => {
      if (entries[0].isIntersecting) animateCounter(entries[0].target);
    }, { threshold: .5 }).observe(el);
  });

  function animateCounter(el) {
    if (el.dataset.animated) return;
    el.dataset.animated = 'true';
    const target = parseInt(el.dataset.target);
    const suffix = el.dataset.suffix || '';
    const duration = 1200;
    const start = performance.now();
    const update = (now) => {
      const progress = Math.min((now - start) / duration, 1);
      const ease = 1 - Math.pow(1 - progress, 3);
      el.textContent = Math.round(ease * target) + suffix;
      if (progress < 1) requestAnimationFrame(update);
    };
    requestAnimationFrame(update);
  }
</script>

</BaseLayout>
