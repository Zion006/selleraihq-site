---
import BaseLayout from '../../layouts/BaseLayout.astro';
const name  = Astro.url.searchParams.get('name')  || 'there';
const store = Astro.url.searchParams.get('store') || 'your store';
export const prerender = false;
---
<BaseLayout
  title="Submitted — FBA Reimbursement Diagnostic"
  description="Your FBA audit diagnostic has been submitted. Results in 24–48 hours."
>
<style>
  .ty-wrap {
    max-width: 560px; margin: 80px auto 120px; text-align: center;
  }
  .ty-icon { font-size: 56px; margin-bottom: 20px; }
  .ty-wrap h1 { font-size: clamp(28px,4vw,42px); margin-bottom: 12px; }
  .ty-wrap p  { color: var(--muted); font-size: 16px; line-height: 1.65; margin-bottom: 28px; }
  .steps-row {
    display: grid; grid-template-columns: repeat(3,1fr); gap: 12px;
    margin: 32px 0;
  }
  .step-box {
    background: var(--panel); border: 1px solid var(--border);
    border-radius: 18px; padding: 18px 14px; text-align: center;
  }
  .step-box .num { font-size: 22px; font-weight: 800; color: var(--accent); margin-bottom: 4px; }
  .step-box span { font-size: 12px; color: var(--muted); }
  @media(max-width:600px){ .steps-row { grid-template-columns: 1fr; } }
</style>

<div class="ty-wrap">
  <div class="ty-icon">✅</div>
  <div class="pill" style="justify-content:center;margin-bottom:14px">Received</div>
  <h1>Got it, {name}!</h1>
  <p>Your files for <strong>{store}</strong> are in our queue. We'll check your last 10 FBA reimbursements against your invoice costs and email you the findings.</p>

  <div class="steps-row">
    <div class="step-box">
      <div class="num">1</div>
      <span>Files received</span>
    </div>
    <div class="step-box">
      <div class="num">24–48h</div>
      <span>Diagnostic turnaround</span>
    </div>
    <div class="step-box">
      <div class="num">📧</div>
      <span>Results by email</span>
    </div>
  </div>

  <p style="font-size:14px">If we find underpayments, we'll send you a full findings report and tell you how to proceed. If there's nothing to pursue, we'll let you know that too.</p>

  <a class="btn primary" href="/" style="margin-top:8px">← Back to SellerAIHQ</a>
</div>

</BaseLayout>
